          Send a Message
        </h3>
        <div class="form-group">
          <label class="form-label" for="from_name">Your Name</label>
          <input class="form-input" id="from_name" name="from_name" type="text" required placeholder="John Doe"/>
        </div>
        <div class="form-group">
          <label class="form-label" for="reply_to">Your Email</label>
          <input class="form-input" id="reply_to" name="reply_to" type="email" required placeholder="john@example.com"/>
        </div>
        <div class="form-group">
          <label class="form-label" for="topic_select">Topic / Purpose</label>
          <select class="form-input" id="topic_select" name="topic">
            <option value="">— Select a topic —</option>
            <option>Java / Spring Boot Role Opportunity</option>
            <option>ML / Gen AI Project Collaboration</option>
            <option>LangChain / RAG Development</option>
            <option>Research Paper Collaboration</option>
            <option>Open Source Contribution</option>
            <option>Security / Cryptography Project</option>
            <option>Full Stack Application Development</option>
            <option>Internship / Full-time Opportunity</option>
            <option>Idea / Feedback / General Inquiry</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label" for="message">Your Message</label>
          <textarea class="form-input" id="message" name="message" rows="5" required placeholder="Tell me about your project, opportunity, or idea. I read every message carefully and reply within 24 hours."></textarea>
