<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Abhay Singh Yadav | Full Stack Java Developer & ML Researcher</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,600&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>
<style>
:root {
  --bg: #020408;
  --bg2: #060c14;
  --bg3: #0a1420;
  --bg4: #0f1c2e;
  --surface: rgba(6,12,20,0.8);
  --surface2: rgba(10,20,32,0.9);
  --cyan: #00d4ff;
  --cyan-dim: rgba(0,212,255,0.12);
  --cyan-glow: rgba(0,212,255,0.3);
  --emerald: #00ff9d;
  --emerald-dim: rgba(0,255,157,0.1);
  --emerald-glow: rgba(0,255,157,0.25);
  --gold: #f5c542;
  --gold2: #ffe87c;
  --gold3: #b8860b;
  --gold-bright: #ffd700;
  --gold-dim: rgba(245,197,66,0.12);
  --gold-glow: rgba(245,197,66,0.35);
  --text: #e8f0fe;
  --text2: #a0b4cc;
  --text3: #556070;
  --border: rgba(255,255,255,0.05);
  --border2: rgba(255,255,255,0.1);
  --border3: rgba(255,255,255,0.18);
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Syne', sans-serif;
  --font-mono: 'DM Mono', monospace;
  --radius: 16px;
  --radius-lg: 24px;
  --radius-sm: 10px;
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; font-size: 16px; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
  line-height: 1.7;
  cursor: default;
}
::selection { background: var(--cyan-glow); color: #fff; }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg); }
::-webkit-scrollbar-thumb { background: linear-gradient(var(--cyan), var(--emerald)); border-radius: 4px; }

#bgCanvas { position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.55; }
.ambient {
  position: fixed; inset: 0; z-index: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 80% 50% at 10% 0%, rgba(0,212,255,0.06) 0%, transparent 60%),
    radial-gradient(ellipse 60% 40% at 90% 100%, rgba(0,255,157,0.05) 0%, transparent 60%),
    radial-gradient(ellipse 50% 60% at 50% 50%, rgba(245,197,66,0.03) 0%, transparent 70%);
  animation: ambientShift 20s ease-in-out infinite alternate;
}
@keyframes ambientShift { 0% { opacity: 1; transform: scale(1); } 100% { opacity: 0.7; transform: scale(1.08) rotate(2deg); } }

#scrollBar {
  position: fixed; top: 0; left: 0; height: 2px; width: 0;
  background: linear-gradient(90deg, var(--cyan), var(--emerald), var(--gold));
  z-index: 9999; box-shadow: 0 0 12px var(--cyan); transition: width 0.1s;
}

.header {
  position: fixed; top: 0; left: 0; right: 0; z-index: 900;
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.1rem 5vw;
  background: rgba(2,4,8,0.7);
  backdrop-filter: blur(30px) saturate(180%);
  border-bottom: 1px solid var(--border);
  transition: all 0.4s;
}
.header.scrolled { padding: 0.7rem 5vw; background: rgba(2,4,8,0.92); border-bottom-color: var(--border2); }

.logo-wrap { display: flex; align-items: center; gap: 0.9rem; text-decoration: none; }
.logo-hex { position: relative; width: 46px; height: 46px; display: flex; align-items: center; justify-content: center; }
.logo-hex::before {
  content: ''; position: absolute; inset: 0;
  background: conic-gradient(var(--cyan) 0deg, var(--emerald) 120deg, var(--gold) 240deg, var(--cyan) 360deg);
  clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  animation: hexSpin 6s linear infinite;
}
@keyframes hexSpin { to { transform: rotate(360deg); } }
.logo-hex::after { content: ''; position: absolute; inset: 2px; background: var(--bg); clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%); }
.logo-letters { position: relative; z-index: 1; font-family: var(--font-display); font-weight: 700; font-size: 0.9rem; background: linear-gradient(135deg, var(--cyan), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 0.05em; }
.logo-name { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; background: linear-gradient(135deg, var(--text), var(--text2)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; letter-spacing: 0.02em; }

.nav { display: flex; gap: 2rem; align-items: center; }
.nav a { color: var(--text2); text-decoration: none; font-size: 0.8rem; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; font-family: var(--font-mono); position: relative; padding: 4px 0; transition: color 0.3s; }
.nav a::after { content: ''; position: absolute; bottom: 0; left: 0; width: 0; height: 1px; background: linear-gradient(90deg, var(--cyan), var(--emerald)); transition: width 0.35s cubic-bezier(0.4,0,0.2,1); }
.nav a:hover { color: var(--text); }
.nav a:hover::after { width: 100%; }
.nav-hire { padding: 7px 18px !important; border: 1px solid rgba(0,212,255,0.35) !important; border-radius: 8px; color: var(--cyan) !important; background: rgba(0,212,255,0.05); transition: all 0.3s !important; }
.nav-hire:hover { background: rgba(0,212,255,0.12) !important; border-color: var(--cyan) !important; box-shadow: 0 0 20px rgba(0,212,255,0.2); }
.nav-hire::after { display: none !important; }
.nav-toggle { display: none; background: transparent; border: none; color: var(--text); font-size: 1.4rem; }

#scrollTop { position: fixed; bottom: 2rem; right: 2rem; width: 44px; height: 44px; border-radius: 12px; background: var(--bg3); border: 1px solid var(--border2); color: var(--cyan); font-size: 1.1rem; display: none; align-items: center; justify-content: center; z-index: 800; transition: all 0.3s; cursor: pointer; backdrop-filter: blur(16px); }
#scrollTop:hover { transform: translateY(-4px); background: var(--cyan-dim); border-color: var(--cyan); box-shadow: 0 8px 24px rgba(0,212,255,0.2); }

.section { padding: 7rem 5vw; position: relative; z-index: 1; }
.container { max-width: 1280px; margin: 0 auto; }

.reveal { opacity: 0; transform: translateY(40px); transition: opacity 0.8s cubic-bezier(0.4,0,0.2,1), transform 0.8s cubic-bezier(0.4,0,0.2,1); }
.reveal.visible { opacity: 1; transform: none; }
.reveal-delay-1 { transition-delay: 0.1s; }
.reveal-delay-2 { transition-delay: 0.2s; }
.reveal-delay-3 { transition-delay: 0.3s; }
.reveal-delay-4 { transition-delay: 0.4s; }
.reveal-delay-5 { transition-delay: 0.5s; }
.reveal-delay-6 { transition-delay: 0.6s; }

.eyebrow { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.25em; text-transform: uppercase; color: var(--emerald); margin-bottom: 0.6rem; display: block; position: relative; padding-left: 22px; }
.eyebrow::before { content: ''; position: absolute; left: 0; top: 50%; width: 14px; height: 1px; background: var(--emerald); transform: translateY(-50%); }
.section-title { font-family: var(--font-display); font-size: clamp(2.2rem, 4vw, 3.4rem); font-weight: 600; line-height: 1.1; margin-bottom: 0.8rem; background: linear-gradient(135deg, var(--text) 40%, rgba(255,255,255,0.4)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
.section-sub { color: var(--text2); font-size: 1rem; max-width: 580px; line-height: 1.85; }

.card { position: relative; overflow: hidden; background: linear-gradient(145deg, rgba(10,18,32,0.95), rgba(6,12,22,0.92)); border: 1px solid rgba(255,255,255,0.09); border-radius: var(--radius-lg); backdrop-filter: blur(28px); transition: transform 0.45s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.45s, border-color 0.45s; box-shadow: 0 4px 24px rgba(0,0,0,0.45), inset 0 1px 0 rgba(255,255,255,0.06); }
.card::before { content: ''; position: absolute; inset: 0; background: radial-gradient(450px circle at var(--mx,50%) var(--my,50%), rgba(0,212,255,0.09), transparent 60%); border-radius: inherit; pointer-events: none; opacity: 0; transition: opacity 0.4s; z-index: 0; }
.card:hover::before { opacity: 1; }
.card:hover { transform: translateY(-10px) scale(1.004); box-shadow: 0 40px 90px rgba(0,0,0,0.7), 0 0 0 1px rgba(0,212,255,0.2), 0 0 40px rgba(0,212,255,0.07), inset 0 1px 0 rgba(255,255,255,0.1); border-color: rgba(0,212,255,0.24); }
.card > * { position: relative; z-index: 1; }
.card-accent { position: absolute; left: 0; top: 20%; bottom: 20%; width: 2px; border-radius: 0 2px 2px 0; background: linear-gradient(180deg, transparent, var(--cyan), transparent); opacity: 0; transition: opacity 0.4s, top 0.4s, bottom 0.4s; }
.card:hover .card-accent { opacity: 1; top: 10%; bottom: 10%; }

.gold-card { position: relative; overflow: hidden; background: linear-gradient(145deg, rgba(40,28,4,0.96) 0%, rgba(30,20,2,0.97) 45%, rgba(44,32,5,0.96) 100%); border: 1px solid rgba(255,216,0,0.42); border-radius: var(--radius-lg); backdrop-filter: blur(28px); transition: transform 0.45s cubic-bezier(0.34,1.56,0.64,1), box-shadow 0.45s; box-shadow: 0 4px 24px rgba(0,0,0,0.5), 0 0 35px rgba(255,200,0,0.1), inset 0 1px 0 rgba(255,220,60,0.12); }
.gold-card::after { content: ''; position: absolute; top: 0; left: -100%; width: 60%; height: 3px; background: linear-gradient(90deg, transparent, rgba(255,248,140,0.6), var(--gold-bright), rgba(255,248,140,0.8), transparent); animation: goldBeam 2.2s ease-in-out infinite; z-index: 2; }
@keyframes goldBeam { 0% { left: -60%; } 100% { left: 165%; } }
.gold-card::before { content: ''; position: absolute; top: -110px; right: -110px; width: 280px; height: 280px; background: radial-gradient(circle, rgba(255,230,70,0.28) 0%, rgba(255,200,0,0.12) 40%, transparent 70%); pointer-events: none; z-index: 0; animation: cornerPulse 3s ease-in-out infinite alternate; }
@keyframes cornerPulse { 0% { transform: scale(1); opacity: 0.85; } 100% { transform: scale(1.5); opacity: 1; } }
.gold-card > * { position: relative; z-index: 1; }
.gold-card:hover { transform: translateY(-12px) scale(1.006); box-shadow: 0 44px 100px rgba(0,0,0,0.7), 0 0 80px rgba(255,210,0,0.25), 0 0 0 1px rgba(255,224,60,0.6), inset 0 0 60px rgba(255,210,0,0.08); border-color: rgba(255,230,60,0.65); }

.gold-card-border { position: absolute; inset: -1px; border-radius: inherit; background: conic-gradient(from var(--angle, 0deg), transparent 10%, rgba(255,240,80,0.8) 32%, var(--gold-bright) 50%, rgba(255,240,80,0.8) 68%, transparent 90%); animation: rotateBorder 3.5s linear infinite; z-index: -1; opacity: 0.85; }
@property --angle { syntax: '<angle>'; initial-value: 0deg; inherits: false; }
@keyframes rotateBorder { to { --angle: 360deg; } }
.gold-card-inner { position: absolute; inset: 1px; border-radius: calc(var(--radius-lg) - 1px); background: linear-gradient(145deg, rgba(40,28,4,0.97), rgba(30,20,2,0.98), rgba(38,26,4,0.97)); z-index: 0; }

.gold-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 20px; background: linear-gradient(135deg, rgba(255,224,60,0.25), rgba(255,200,0,0.12)); border: 1px solid rgba(255,220,40,0.6); font-size: 0.65rem; font-family: var(--font-mono); color: var(--gold2); letter-spacing: 0.14em; text-transform: uppercase; font-weight: 600; box-shadow: 0 0 24px rgba(255,210,0,0.3), inset 0 0 14px rgba(255,210,0,0.1); animation: badgePulse 2.5s ease-in-out infinite; white-space: nowrap; }
@keyframes badgePulse { 0%,100% { box-shadow: 0 0 18px rgba(255,210,0,0.25), inset 0 0 12px rgba(255,210,0,0.08); } 50% { box-shadow: 0 0 40px rgba(255,210,0,0.55), inset 0 0 28px rgba(255,210,0,0.18); } }
.badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--gold2); box-shadow: 0 0 10px var(--gold2), 0 0 22px rgba(255,230,60,0.6); animation: dotBlink 1.4s ease-in-out infinite; }
@keyframes dotBlink { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.3; transform: scale(0.5); } }

.status-active { display: inline-flex; align-items: center; gap: 6px; padding: 3px 10px; border-radius: 20px; background: rgba(0,255,157,0.08); border: 1px solid rgba(0,255,157,0.3); font-size: 0.65rem; font-family: var(--font-mono); color: var(--emerald); letter-spacing: 0.12em; text-transform: uppercase; }
.status-selected { display: inline-flex; align-items: center; gap: 5px; padding: 3px 10px; border-radius: 20px; background: rgba(0,212,255,0.08); border: 1px solid rgba(0,212,255,0.3); font-size: 0.65rem; font-family: var(--font-mono); color: var(--cyan); letter-spacing: 0.12em; text-transform: uppercase; }

.btn { display: inline-flex; align-items: center; gap: 8px; padding: 0.75rem 1.65rem; border-radius: var(--radius-sm); font-family: var(--font-body); font-size: 0.9rem; font-weight: 600; text-decoration: none; border: none; transition: all 0.35s cubic-bezier(0.34,1.56,0.64,1); position: relative; overflow: hidden; cursor: pointer; letter-spacing: 0.02em; }
.btn-primary { background: linear-gradient(135deg, var(--cyan), #0099cc); color: #000; box-shadow: 0 6px 24px rgba(0,212,255,0.25); }
.btn-primary:hover { transform: translateY(-3px); box-shadow: 0 16px 45px rgba(0,212,255,0.45); }
.btn-gold { background: linear-gradient(135deg, var(--gold3), var(--gold), var(--gold2)); color: #0a0800; font-weight: 700; box-shadow: 0 6px 24px rgba(245,197,66,0.3); }
.btn-gold:hover { transform: translateY(-3px); box-shadow: 0 16px 45px rgba(245,197,66,0.5), 0 0 0 1px rgba(245,197,66,0.4); }
.btn-ghost { background: transparent; border: 1px solid var(--border2); color: var(--text2); }
.btn-ghost:hover { border-color: var(--cyan); color: var(--cyan); background: var(--cyan-dim); transform: translateY(-3px); }
.btn::before { content: ''; position: absolute; top: 0; left: -120%; width: 80%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent); transition: left 0.5s; }
.btn:hover::before { left: 150%; }

.hero-section { min-height: 100vh; display: grid; grid-template-columns: 1.5fr 1fr; gap: 2rem; align-items: center; padding: 8rem 5vw 5rem; position: relative; z-index: 1; }
.hero-grid-overlay { position: absolute; inset: 0; pointer-events: none; z-index: 0; background-image: linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px); background-size: 60px 60px; mask-image: radial-gradient(ellipse 70% 80% at 50% 50%, black, transparent); }

.hero-tag { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 8px; background: rgba(0,255,157,0.06); border: 1px solid rgba(0,255,157,0.2); font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--emerald); margin-bottom: 1.6rem; font-family: var(--font-mono); }
.live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--emerald); box-shadow: 0 0 10px var(--emerald); animation: dotBlink 1.5s infinite; }

.hero-name { font-family: var(--font-display); font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 700; line-height: 1.1; margin-bottom: 0.5rem; }
.hero-name-accent { display: block; background: linear-gradient(135deg, var(--cyan), var(--emerald)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; position: relative; }
.hero-name-accent::after { content: ''; position: absolute; bottom: -4px; left: 0; height: 2px; width: 0; background: linear-gradient(90deg, var(--cyan), var(--emerald)); animation: lineReveal 1.2s ease-out 0.6s both; border-radius: 2px; }
@keyframes lineReveal { to { width: 100%; } }

.hero-role { font-size: 1.2rem; color: var(--text2); margin-bottom: 1.4rem; font-weight: 400; }
.typing-wrap { display: inline-flex; align-items: center; gap: 2px; }
.cursor-type { color: var(--cyan); animation: typeBlink 1s step-end infinite; }
@keyframes typeBlink { 0%,100%{opacity:1} 50%{opacity:0} }

.hero-bio { font-size: 0.95rem; color: var(--text2); max-width: 520px; line-height: 1.9; margin-bottom: 2.2rem; }
.hero-cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem; }

.hero-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 1rem; padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border); background: rgba(6,12,20,0.6); backdrop-filter: blur(16px); }
.stat-num { font-family: var(--font-display); font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, var(--cyan), var(--emerald)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1; }
.stat-label { font-size: 0.7rem; color: var(--text3); font-family: var(--font-mono); letter-spacing: 0.1em; text-transform: uppercase; margin-top: 4px; }

.hero-right { display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2rem; padding: 2rem; }
.avatar-wrap { position: relative; width: 260px; height: 260px; }
.avatar-ring { position: absolute; inset: -16px; border-radius: 50%; border: 1px solid transparent; background: conic-gradient(from 0deg, var(--cyan), var(--emerald), var(--gold), transparent, var(--cyan)) border-box; -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0); -webkit-mask-composite: destination-out; mask-composite: exclude; animation: ringRotate 8s linear infinite; }
@keyframes ringRotate { to { transform: rotate(360deg); } }
.avatar-ring2 { position: absolute; inset: -6px; border-radius: 50%; border: 1px solid rgba(0,212,255,0.15); animation: ringRotate 12s linear infinite reverse; }
.avatar-ring2::before, .avatar-ring2::after { content: ''; position: absolute; width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); box-shadow: 0 0 10px var(--cyan); }
.avatar-ring2::before { top: -3px; left: 50%; transform: translateX(-50%); }
.avatar-ring2::after { bottom: -3px; left: 50%; transform: translateX(-50%); background: var(--gold); box-shadow: 0 0 10px var(--gold); }
.avatar-circle { width: 100%; height: 100%; border-radius: 50%; background: radial-gradient(circle at 35% 35%, #0f2040, #040810); border: 1px solid rgba(0,212,255,0.2); display: flex; align-items: center; justify-content: center; font-family: var(--font-display); font-weight: 700; font-size: 2.2rem; cursor: pointer; transition: all 0.4s; box-shadow: 0 0 60px rgba(0,212,255,0.1), inset 0 0 60px rgba(0,212,255,0.05); overflow: hidden; position: relative; }
.avatar-circle::before { content: ''; position: absolute; inset: -50%; background: conic-gradient(from 0deg, transparent 70%, rgba(0,212,255,0.15) 80%, rgba(245,197,66,0.1) 90%, transparent 100%); animation: avatarAura 6s linear infinite; }
@keyframes avatarAura { to { transform: rotate(360deg); } }
.avatar-initials { position: relative; z-index: 1; background: linear-gradient(135deg, var(--cyan), var(--gold)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; user-select: none; }
.avatar-circle:hover { box-shadow: 0 0 80px rgba(0,212,255,0.25), 0 0 0 2px rgba(245,197,66,0.3); transform: scale(1.05); }

.orbit-chips { display: flex; flex-wrap: wrap; gap: 6px; justify-content: center; max-width: 300px; }
.orbit-chip { font-size: 0.68rem; padding: 5px 10px; border-radius: 6px; background: rgba(10,20,32,0.9); border: 1px solid var(--border2); color: var(--text2); font-family: var(--font-mono); transition: all 0.25s; display: flex; align-items: center; gap: 5px; }
.orbit-chip:hover { color: var(--cyan); border-color: rgba(0,212,255,0.35); background: rgba(0,212,255,0.06); transform: translateY(-2px); }
.orbit-chip svg { width: 13px; height: 13px; flex-shrink: 0; }

.emoji-burst { position: fixed; font-size: 1.4rem; pointer-events: none; z-index: 9999; animation: emojiFly 1s ease-out forwards; }
@keyframes emojiFly { 0% { transform: translate(0,0) scale(1) rotate(0deg); opacity: 1; } 100% { transform: translate(var(--tx), var(--ty)) scale(0) rotate(540deg); opacity: 0; } }

.about-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 2rem; margin-top: 3rem; }
.about-card { padding: 2.5rem; }
.about-title { font-family: var(--font-display); font-size: 1.6rem; font-weight: 600; margin-bottom: 1.3rem; }
.about-text { color: var(--text2); font-size: 0.93rem; line-height: 1.9; margin-bottom: 1rem; }
.about-text strong { color: var(--text); }

.timeline { margin-top: 0.5rem; }
.timeline-item { display: flex; gap: 1.2rem; padding: 1rem 0.8rem; border-bottom: 1px solid var(--border); transition: all 0.4s; cursor: default; border-radius: 10px; position: relative; }
.timeline-item:last-child { border-bottom: none; }
.timeline-item:hover { padding-left: 1.2rem; background: rgba(255,255,255,0.02); }
.timeline-item.in-progress { background: linear-gradient(135deg, rgba(255,200,0,0.04), rgba(255,180,0,0.02)); border-bottom-color: rgba(255,200,0,0.12); border-radius: 10px; }
.timeline-item.in-progress::before { content: ''; position: absolute; left: 0; top: 15%; bottom: 15%; width: 2px; border-radius: 0 2px 2px 0; background: linear-gradient(180deg, transparent, rgba(255,210,0,0.8), transparent); box-shadow: 0 0 8px rgba(255,210,0,0.4); }
.timeline-item.in-progress .t-year { color: rgba(255,210,50,0.85) !important; }
.timeline-item.in-progress .t-title { color: var(--gold2) !important; text-shadow: 0 0 20px rgba(255,210,0,0.25); }
.timeline-item.in-progress .t-sub { color: rgba(200,160,30,0.7); }
.timeline-item.in-progress:hover { background: linear-gradient(135deg, rgba(255,210,0,0.08), rgba(255,180,0,0.04)); padding-left: 1.4rem; }
.t-year { font-family: var(--font-mono); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.15em; color: var(--emerald); min-width: 90px; padding-top: 3px; font-weight: 500; transition: color 0.4s; }
.t-title { font-size: 0.93rem; font-weight: 600; margin-bottom: 2px; transition: all 0.4s; }
.t-sub { color: var(--text3); font-size: 0.82rem; line-height: 1.5; }

.skills-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.8rem; margin-top: 3rem; }
.skill-card { padding: 2rem 2.2rem 2.2rem; min-height: 340px; display: flex; flex-direction: column; }
.skill-card::after { content: ''; position: absolute; top: 0; left: 10%; right: 10%; height: 2px; border-radius: 0 0 4px 4px; background: linear-gradient(90deg, transparent, rgba(0,212,255,0.5), transparent); opacity: 0; transition: opacity 0.4s; }
.skill-card:hover::after { opacity: 1; }
.skill-card-title { font-family: var(--font-mono); font-size: 0.85rem; font-weight: 600; display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem; letter-spacing: 0.06em; padding-bottom: 1rem; border-bottom: 1px solid var(--border2); color: var(--text); }
.skill-icon-wrap { width: 40px; height: 40px; border-radius: 10px; display: flex; align-items: center; justify-content: center; background: linear-gradient(135deg, rgba(0,212,255,0.08), rgba(0,255,157,0.05)); border: 1px solid rgba(0,212,255,0.2); flex-shrink: 0; box-shadow: 0 0 16px rgba(0,212,255,0.08); transition: all 0.3s; }
.skill-card:hover .skill-icon-wrap { background: linear-gradient(135deg, rgba(0,212,255,0.15), rgba(0,255,157,0.1)); border-color: rgba(0,212,255,0.4); box-shadow: 0 0 24px rgba(0,212,255,0.2); }
.skill-icon-wrap svg, .skill-icon-wrap img { width: 20px; height: 20px; }

.skill-list { list-style: none; flex: 1; }
.skill-item { display: flex; justify-content: space-between; align-items: center; padding: 9px 8px; font-size: 0.88rem; color: var(--text2); border-bottom: 1px solid rgba(255,255,255,0.04); transition: all 0.3s; border-radius: 6px; margin-bottom: 2px; }
.skill-item:last-child { border-bottom: none; }
.skill-item:hover { color: var(--text); padding-left: 14px; background: rgba(0,212,255,0.04); border-bottom-color: rgba(0,212,255,0.08); }
.skill-pill { font-size: 0.64rem; padding: 3px 9px; border-radius: 20px; background: rgba(0,212,255,0.07); border: 1px solid rgba(0,212,255,0.22); color: var(--cyan); font-family: var(--font-mono); transition: all 0.3s; white-space: nowrap; flex-shrink: 0; letter-spacing: 0.04em; }
.skill-item:hover .skill-pill { background: linear-gradient(135deg, var(--emerald), #00cc7a); color: #000; border-color: var(--emerald); box-shadow: 0 0 10px rgba(0,255,157,0.3); }

.gold-skill-title { font-family: var(--font-mono); font-size: 0.85rem; display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 8px; padding-bottom: 1rem; border-bottom: 1px solid rgba(245,197,66,0.15); }
.gold-skill-title-left { display: flex; align-items: center; gap: 12px; color: var(--gold2); font-weight: 600; letter-spacing: 0.06em; }
.gold-pill { font-size: 0.64rem; padding: 3px 9px; border-radius: 20px; background: rgba(245,197,66,0.12); border: 1px solid rgba(245,197,66,0.35); color: var(--gold2); font-family: var(--font-mono); white-space: nowrap; flex-shrink: 0; letter-spacing: 0.04em; }
.skill-item:hover .gold-pill { background: linear-gradient(135deg, var(--gold), var(--gold2)); color: #1a1000; border-color: var(--gold2); box-shadow: 0 0 10px rgba(245,197,66,0.35); }

.filter-bar { display: inline-flex; gap: 4px; padding: 4px; background: rgba(6,12,20,0.8); border: 1px solid var(--border); border-radius: 12px; margin-bottom: 2.5rem; margin-top: 3rem; backdrop-filter: blur(16px); }
.filter-btn { border: none; border-radius: 8px; background: transparent; color: var(--text2); padding: 6px 16px; font-size: 0.78rem; font-family: var(--font-mono); transition: all 0.3s; cursor: pointer; letter-spacing: 0.05em; }
.filter-btn.active { background: var(--cyan); color: #000; font-weight: 600; }
.filter-btn:not(.active):hover { color: var(--text); background: rgba(255,255,255,0.05); }

.projects-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px,1fr)); gap: 1.8rem; }
.project-card { padding: 2rem; }
.proj-label { font-family: var(--font-mono); font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text3); margin-bottom: 6px; display: block; }
.proj-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 0.7rem; line-height: 1.35; display: flex; align-items: center; gap: 8px; }
.proj-desc { color: var(--text2); font-size: 0.86rem; line-height: 1.8; margin-bottom: 1.1rem; }
.proj-tags { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 1.1rem; }
.proj-tag { font-size: 0.63rem; padding: 3px 9px; border-radius: 6px; background: rgba(10,20,32,0.8); border: 1px solid var(--border2); color: var(--text3); font-family: var(--font-mono); transition: all 0.25s; }
.proj-tag:hover { color: var(--cyan); border-color: rgba(0,212,255,0.3); }
.proj-link { font-size: 0.8rem; color: var(--cyan); text-decoration: none; font-weight: 600; display: inline-flex; align-items: center; gap: 5px; font-family: var(--font-mono); transition: gap 0.3s, color 0.3s; }
.proj-link:hover { gap: 10px; color: var(--emerald); }
.gold-card .proj-title { color: var(--gold2); }
.gold-card .proj-link { color: var(--gold); }
.gold-card .proj-link:hover { color: var(--gold2); }
.gold-card .proj-tag { background: rgba(26,18,2,0.8); border-color: rgba(245,197,66,0.2); }
.gold-card .proj-tag:hover { color: var(--gold); border-color: rgba(245,197,66,0.4); }

.proj-icon { width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; border-radius: 7px; flex-shrink: 0; }
.proj-icon svg { width: 16px; height: 16px; }

.research-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 3rem; }
.research-card { padding: 2rem; }
.research-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.8rem; gap: 1rem; }
.research-title { font-size: 1.05rem; font-weight: 700; line-height: 1.4; display: flex; align-items: flex-start; gap: 8px; }
.research-title-icon { width: 24px; height: 24px; flex-shrink: 0; margin-top: 1px; }
.research-desc { color: var(--text2); font-size: 0.86rem; line-height: 1.85; margin-bottom: 1rem; }
.research-chips { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 0.8rem; }
.r-chip { font-size: 0.62rem; padding: 3px 10px; border-radius: 20px; font-family: var(--font-mono); letter-spacing: 0.05em; }
.r-chip-conf { background: rgba(102,126,234,0.1); border: 1px solid rgba(102,126,234,0.3); color: #a78bfa; }
.r-chip-domain { background: var(--cyan-dim); border: 1px solid rgba(0,212,255,0.2); color: var(--cyan); }
.r-chip-gold { background: var(--gold-dim); border: 1px solid rgba(245,197,66,0.3); color: var(--gold2); }
.r-chip-green { background: var(--emerald-dim); border: 1px solid rgba(0,255,157,0.25); color: var(--emerald); }

.cert-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px,1fr)); gap: 1.5rem; margin-top: 3rem; }
.cert-card { padding: 1.7rem; display: flex; flex-direction: column; gap: 0.8rem; }
.cert-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border2); background: rgba(255,255,255,0.03); flex-shrink: 0; }
.cert-icon svg { width: 26px; height: 26px; }
.cert-title { font-size: 0.95rem; font-weight: 700; line-height: 1.35; }
.cert-issuer { font-family: var(--font-mono); font-size: 0.68rem; color: var(--text3); text-transform: uppercase; letter-spacing: 0.1em; }
.cert-year { font-family: var(--font-mono); font-size: 0.65rem; color: var(--emerald); padding: 2px 8px; border-radius: 4px; background: rgba(0,255,157,0.06); border: 1px solid rgba(0,255,157,0.15); align-self: flex-start; }
.cert-skills { display: flex; flex-wrap: wrap; gap: 4px; }
.cert-tag { font-size: 0.6rem; padding: 2px 7px; border-radius: 4px; background: var(--bg4); border: 1px solid var(--border); color: var(--text3); font-family: var(--font-mono); }

.cv-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; margin-top: 3rem; }
.cv-card { padding: 2.5rem; text-align: center; }
.cv-icon-wrap { width: 70px; height: 70px; border-radius: 18px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; border: 1px solid var(--border2); background: rgba(255,255,255,0.03); animation: floatAnim 3s ease-in-out infinite; }
.cv-icon-wrap svg { width: 34px; height: 34px; }
.cv-icon-wrap.gold-icon { background: rgba(245,197,66,0.08); border-color: rgba(245,197,66,0.25); }
@keyframes floatAnim { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
.cv-title { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; margin-bottom: 0.7rem; }
.cv-desc { color: var(--text2); font-size: 0.87rem; line-height: 1.8; margin-bottom: 1.4rem; }
.cv-features { list-style: none; text-align: left; margin-bottom: 1.5rem; }
.cv-feature { display: flex; align-items: center; gap: 8px; font-size: 0.84rem; color: var(--text2); padding: 4px 0; }
.cv-feature::before { content: '▸'; color: var(--emerald); font-size: 0.7rem; flex-shrink: 0; }

.contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 2rem; margin-top: 3rem; }
.contact-card { padding: 2.5rem; }
.contact-title { font-family: var(--font-display); font-size: 1.4rem; font-weight: 600; margin-bottom: 1.5rem; color: var(--cyan); }
.contact-list { list-style: none; }
.contact-item { display: flex; align-items: flex-start; gap: 12px; padding: 0.75rem 0.5rem; border-radius: 10px; margin-bottom: 0.4rem; transition: all 0.3s; border: 1px solid transparent; }
.contact-item:hover { background: rgba(0,212,255,0.04); border-color: rgba(0,212,255,0.1); padding-left: 0.9rem; }
.contact-item-icon { width: 38px; height: 38px; border-radius: 10px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; border: 1px solid var(--border2); background: rgba(255,255,255,0.03); transition: all 0.3s; }
.contact-item-icon svg { width: 18px; height: 18px; }
.contact-item:hover .contact-item-icon { background: var(--cyan-dim); border-color: rgba(0,212,255,0.3); }
.contact-item-label { font-size: 0.68rem; color: var(--text3); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 2px; }
.contact-item-value { font-size: 0.9rem; color: var(--text2); }
.contact-item-value a { color: var(--cyan); text-decoration: none; transition: color 0.3s; }
.contact-item-value a:hover { color: var(--emerald); }

.social-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.7rem; margin-top: 1.5rem; }
.social-btn { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 10px 8px; border-radius: 10px; background: var(--bg3); border: 1px solid var(--border2); text-decoration: none; font-size: 0.72rem; font-family: var(--font-mono); color: var(--text2); transition: all 0.3s; position: relative; overflow: hidden; }
.social-btn::before { content: ''; position: absolute; inset: 0; background: var(--sb-color, rgba(0,212,255,0.08)); opacity: 0; transition: opacity 0.3s; }
.social-btn:hover::before { opacity: 1; }
.social-btn:hover { color: var(--sb-text, var(--cyan)); border-color: var(--sb-border, rgba(0,212,255,0.35)); transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.4); }
.social-btn svg, .social-btn span.s-icon { position: relative; z-index: 1; width: 15px; height: 15px; }
.social-btn span.s-label { position: relative; z-index: 1; }
.sb-github { --sb-color: rgba(230,237,243,0.07); --sb-text: #e6edf3; --sb-border: rgba(230,237,243,0.25); }
.sb-linkedin { --sb-color: rgba(10,102,194,0.1); --sb-text: #0a66c2; --sb-border: rgba(10,102,194,0.35); }
.sb-instagram { --sb-color: rgba(225,48,108,0.08); --sb-text: #e1306c; --sb-border: rgba(225,48,108,0.3); }
.sb-twitter { --sb-color: rgba(29,155,240,0.08); --sb-text: #1d9bf0; --sb-border: rgba(29,155,240,0.3); }
.sb-phone { --sb-color: rgba(34,197,94,0.08); --sb-text: #22c55e; --sb-border: rgba(34,197,94,0.3); }
.sb-email { --sb-color: rgba(245,197,66,0.08); --sb-text: var(--gold2); --sb-border: rgba(245,197,66,0.3); }

.form-group { margin-bottom: 1.1rem; }
.form-label { display: block; font-size: 0.68rem; margin-bottom: 6px; color: var(--emerald); font-family: var(--font-mono); text-transform: uppercase; letter-spacing: 0.12em; font-weight: 500; }
.form-input { width: 100%; padding: 0.75rem 1rem; border-radius: 10px; border: 1px solid var(--border2); background: rgba(6,12,20,0.9); color: var(--text); font-family: var(--font-body); font-size: 0.9rem; transition: all 0.3s; outline: none; }
.form-input:focus { border-color: var(--emerald); box-shadow: 0 0 0 3px rgba(0,255,157,0.08); }
.form-input option { background: var(--bg2); color: var(--text); }

.btn-send { width: 100%; justify-content: center; padding: 1rem; font-size: 0.95rem; border-radius: 12px; background: linear-gradient(135deg, #00b44a, #00d467); color: #000; font-weight: 700; box-shadow: 0 8px 30px rgba(0,212,103,0.3); border: none; cursor: pointer; transition: all 0.4s cubic-bezier(0.34,1.56,0.64,1); position: relative; overflow: hidden; }
.btn-send::before { content: ''; position: absolute; top:0; left:-100%; width:100%; height:100%; background: linear-gradient(90deg,transparent,rgba(255,255,255,0.2),transparent); transition: left 0.5s; }
.btn-send:hover::before { left: 100%; }
.btn-send:hover { transform: translateY(-4px) scale(1.01); box-shadow: 0 20px 55px rgba(0,212,103,0.45); }
.btn-send .send-arrow { transition: transform 0.3s, rotate 0.3s; }
.btn-send:hover .send-arrow { transform: translateX(4px) rotate(-15deg); }

.form-msg { font-size: 0.85rem; margin-top: 0.9rem; padding: 0.75rem 1rem; border-radius: 10px; display: none; }
.form-msg.success { background: rgba(0,255,157,0.07); border: 1px solid var(--emerald); color: var(--emerald); display: block; }
.form-msg.error { background: rgba(239,68,68,0.07); border: 1px solid #ef4444; color: #ef4444; display: block; }

.footer { padding: 3rem 5vw; text-align: center; border-top: 1px solid var(--border); font-size: 0.82rem; color: var(--text3); position: relative; z-index: 1; }
.footer-icons { display: flex; justify-content: center; gap: 1rem; margin-bottom: 1.2rem; }
.footer-icon { width: 38px; height: 38px; border-radius: 10px; background: var(--bg3); border: 1px solid var(--border2); display: flex; align-items: center; justify-content: center; text-decoration: none; transition: all 0.3s; }
.footer-icon svg { width: 16px; height: 16px; }
.footer-icon:hover { transform: translateY(-4px); border-color: var(--cyan); background: var(--cyan-dim); }
.footer-brand { font-family: var(--font-mono); font-size: 0.72rem; color: var(--text3); margin-top: 6px; }

.section-divider { width: 100%; height: 1px; background: linear-gradient(90deg, transparent, var(--border2), transparent); margin: 0 5vw; max-width: 90vw; }

.about-meta { display: flex; align-items: center; gap: 6px; margin-top: 1rem; font-size: 0.82rem; color: var(--text3); }
.about-meta svg { width: 14px; height: 14px; flex-shrink: 0; }
.about-meta-sep { color: var(--border3); }

.spin-slow { animation: iconSpin 8s linear infinite; transform-origin: center; }
.spin-pulse { animation: iconPulse 2s ease-in-out infinite; }
.float-icon { animation: floatIcon 3s ease-in-out infinite; }
.float-icon-2 { animation: floatIcon 3s ease-in-out infinite 0.8s; }
.float-icon-3 { animation: floatIcon 3s ease-in-out infinite 1.6s; }
@keyframes iconSpin { to { transform: rotate(360deg); } }
@keyframes iconPulse { 0%,100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.7; transform: scale(0.92); } }
@keyframes floatIcon { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-3px); } }

@media (max-width: 1100px) { .skills-grid { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 900px) {
  .hero-section, .about-grid, .research-grid, .contact-grid, .cv-grid { grid-template-columns: 1fr; }
  .hero-right { order: -1; }
}
@media (max-width: 720px) {
  .nav { position: fixed; top: 66px; left: 0; right: 0; flex-direction: column; background: rgba(2,4,8,0.98); padding: 1.8rem 5vw; border-bottom: 1px solid var(--border); opacity: 0; visibility: hidden; transform: translateY(-10px); transition: all 0.3s; gap: 1.2rem; z-index: 850; }
  .nav.open { opacity: 1; visibility: visible; transform: translateY(0); }
  .nav-toggle { display: block; }
  .skills-grid { grid-template-columns: 1fr; }
  .section { padding: 5rem 4vw; }
  .social-grid { grid-template-columns: repeat(2,1fr); }
}
@media (max-width: 500px) {
  .projects-grid { grid-template-columns: 1fr; }
  .cert-grid { grid-template-columns: 1fr; }
  .hero-cta { flex-direction: column; }
  .hero-stats { grid-template-columns: 1fr; }
  .cv-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<canvas id="bgCanvas"></canvas>
<div class="ambient"></div>
<div id="scrollBar"></div>

<header class="header" id="header">
  <a href="#home" class="logo-wrap">
    <div class="logo-hex">
      <span class="logo-letters">ASY</span>
    </div>
    <span class="logo-name">Abhay Singh Yadav</span>
  </a>
  <nav class="nav" id="nav">
    <a href="#home">Home</a>
    <a href="#about">About</a>
    <a href="#skills">Skills</a>
    <a href="#projects">Projects</a>
    <a href="#research">Research</a>
    <a href="#certifications">Certs</a>
    <a href="#cv">Resume</a>
    <a href="#contact" class="nav-hire">Hire Me</a>
  </nav>
  <button id="navToggle" class="nav-toggle" aria-label="Menu">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  </button>
</header>

<button id="scrollTop" aria-label="Scroll to top">
  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
</button>

<section id="home" class="hero-section">
  <div class="hero-grid-overlay"></div>
  <div class="reveal">
    <p class="hero-tag">
      <span class="live-dot"></span>
      Available for Opportunities
    </p>
    <h1 class="hero-name">
      <span style="color:var(--text);">Hi, I'm</span>
      <span class="hero-name-accent">Abhay Singh Yadav</span>
    </h1>
    <p class="hero-role">
      <span class="typing-wrap">
        <span id="typingText"></span><span class="cursor-type">|</span>
      </span>
    </p>
    <p class="hero-bio">
      B.Tech CSE @ Lovely Professional University. Building enterprise-grade
      <strong style="color:var(--text)">Spring Boot</strong> systems,
      <strong style="color:var(--text)">Gen AI / LangChain RAG</strong> pipelines,
      and publishing research in low-resource NLP &amp; Emotional AI.
    </p>
    <div class="hero-cta">
      <a href="#projects" class="btn btn-primary">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        View Projects
      </a>
      <a href="#cv" class="btn btn-gold">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Download CV
      </a>
      <a href="#contact" class="btn btn-ghost">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        Let's Talk
      </a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">8+</div>
        <div class="stat-label">Projects Built</div>
      </div>
      <div>
        <div class="stat-num">2</div>
        <div class="stat-label">Research Papers</div>
      </div>
      <div>
        <div class="stat-num">2027</div>
        <div class="stat-label">Graduating</div>
      </div>
    </div>
  </div>

  <div class="hero-right reveal reveal-delay-3">
    <div class="avatar-wrap">
      <div class="avatar-ring"></div>
      <div class="avatar-ring2"></div>
      <div class="avatar-circle" id="avatarCircle" title="Click me!">
