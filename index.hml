      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
    </a>
    <a href="https://github.com/abhay9889" target="_blank" class="footer-icon" title="Portfolio">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
    </a>
  </div>
  <p>&copy; <span id="footerYear"></span> <strong style="color:var(--text2)">Abhay Singh Yadav</strong>. All rights reserved.</p>
  <p class="footer-brand" style="margin-top:6px;">Crafted with Java · Spring Boot · AI/ML — Ready for backend integration</p>
</footer>

<script>
(function() {
'use strict';

try { emailjs.init("37TD4JYgrHefjEfLT"); } catch(e) {}

const canvas = document.getElementById('bgCanvas');
const ctx = canvas.getContext('2d');
let W, H, particles = [];

function resize() { W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
resize();
window.addEventListener('resize', () => { resize(); initParticles(); });

const COLORS = ['rgba(0,212,255,', 'rgba(0,255,157,', 'rgba(245,197,66,'];
function randColor(a) { return COLORS[Math.floor(Math.random() * COLORS.length)] + a + ')'; }

function initParticles() {
  particles = [];
  const count = Math.floor((W * H) / 12000);
  for (let i = 0; i < count; i++) {
    particles.push({ x: Math.random() * W, y: Math.random() * H, vx: (Math.random() - 0.5) * 0.4, vy: (Math.random() - 0.5) * 0.4, r: Math.random() * 1.8 + 0.8, color: randColor(Math.random() * 0.7 + 0.3), pulse: Math.random() * Math.PI * 2, pulseSpeed: Math.random() * 0.02 + 0.01 });
  }
}
initParticles();

let mouseX = W / 2, mouseY = H / 2;
document.addEventListener('mousemove', e => { mouseX = e.clientX; mouseY = e.clientY; });

let stars = [];
function spawnStar() {
  stars.push({ x: Math.random() * W, y: Math.random() * H * 0.5, len: Math.random() * 80 + 40, speed: Math.random() * 8 + 4, angle: Math.PI / 6 + (Math.random() - 0.5) * 0.4, life: 1, color: COLORS[Math.floor(Math.random() * COLORS.length)] });
}
function drawStars() {
  stars = stars.filter(s => s.life > 0);
  stars.forEach(s => {
    const dx = Math.cos(s.angle) * s.len, dy = Math.sin(s.angle) * s.len;
    const grad = ctx.createLinearGradient(s.x, s.y, s.x + dx, s.y + dy);
    grad.addColorStop(0, s.color + s.life.toFixed(2) + ')');
    grad.addColorStop(1, 'transparent');
    ctx.beginPath(); ctx.moveTo(s.x, s.y); ctx.lineTo(s.x + dx, s.y + dy);
    ctx.strokeStyle = grad; ctx.lineWidth = 1.5; ctx.stroke();
    s.x += Math.cos(s.angle) * s.speed; s.y += Math.sin(s.angle) * s.speed; s.life -= 0.03;
  });
}

function drawFrame() {
  ctx.clearRect(0, 0, W, H);
  for (let i = 0; i < particles.length; i++) {
    for (let j = i + 1; j < particles.length; j++) {
      const dx = particles[i].x - particles[j].x, dy = particles[i].y - particles[j].y;
      const dist = Math.sqrt(dx*dx + dy*dy);
      if (dist < 130) {
        ctx.beginPath(); ctx.moveTo(particles[i].x, particles[i].y); ctx.lineTo(particles[j].x, particles[j].y);
        ctx.strokeStyle = `rgba(0,212,255,${(1 - dist/130) * 0.18})`; ctx.lineWidth = 0.6; ctx.stroke();
      }
    }
  }
  particles.forEach(p => {
    const dx = mouseX - p.x, dy = mouseY - p.y, dist = Math.sqrt(dx*dx + dy*dy);
    if (dist < 200) { p.vx += dx * 0.00008; p.vy += dy * 0.00008; }
    const spd = Math.sqrt(p.vx*p.vx + p.vy*p.vy);
    if (spd > 1.2) { p.vx *= 0.95; p.vy *= 0.95; }
    p.x += p.vx; p.y += p.vy; p.pulse += p.pulseSpeed;
    if (p.x < 0) p.x = W; if (p.x > W) p.x = 0; if (p.y < 0) p.y = H; if (p.y > H) p.y = 0;
    const pr = Math.max(0.3, p.r + Math.sin(p.pulse) * 0.4), glowR = Math.max(0.5, pr * 3);
    ctx.beginPath(); ctx.arc(p.x, p.y, pr, 0, Math.PI * 2); ctx.fillStyle = p.color; ctx.fill();
    ctx.beginPath(); ctx.arc(p.x, p.y, glowR, 0, Math.PI * 2);
    const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, glowR);
    grad.addColorStop(0, p.color.replace(')', '').replace(/,[^,]+$/, ',0.12)')); grad.addColorStop(1, 'transparent');
    ctx.fillStyle = grad; ctx.fill();
  });
  if (Math.random() < 0.003) spawnStar();
  drawStars();
  requestAnimationFrame(drawFrame);
}
drawFrame();

const scrollBar = document.getElementById('scrollBar');
const scrollTopBtn = document.getElementById('scrollTop');
const header = document.getElementById('header');

window.addEventListener('scroll', () => {
  const st = document.documentElement.scrollTop;
  const h = document.documentElement.scrollHeight - document.documentElement.clientHeight;
  scrollBar.style.width = (st / h * 100) + '%';
  scrollTopBtn.style.display = st > 300 ? 'flex' : 'none';
  header.classList.toggle('scrolled', st > 50);
});
scrollTopBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));

const revealObs = new IntersectionObserver(entries => {
  entries.forEach(entry => { if (entry.isIntersecting) { entry.target.classList.add('visible'); revealObs.unobserve(entry.target); } });
}, { threshold: 0.08 });
document.querySelectorAll('.reveal').forEach(el => revealObs.observe(el));

document.querySelectorAll('.card, .gold-card').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', (e.clientX - r.left) + 'px');
    card.style.setProperty('--my', (e.clientY - r.top) + 'px');
  });
});

const navToggle = document.getElementById('navToggle');
const nav = document.getElementById('nav');
navToggle.addEventListener('click', () => nav.classList.toggle('open'));
nav.querySelectorAll('a').forEach(a => a.addEventListener('click', () => nav.classList.remove('open')));

const roles = ['Full Stack Java Developer','Spring Boot Expert','Gen AI & LangChain Builder','ML / Deep Learning Engineer','NLP Researcher','DSA Specialist (Java / C++)'];
let ri = 0, ci = 0, erasing = false;
const typingEl = document.getElementById('typingText');
function typeLoop() {
  if (!typingEl) return;
  const cur = roles[ri];
  if (!erasing) {
    if (ci <= cur.length) { typingEl.textContent = cur.slice(0, ci++); setTimeout(typeLoop, 72); }
    else { erasing = true; setTimeout(typeLoop, 1800); }
  } else {
    if (ci >= 0) { typingEl.textContent = cur.slice(0, ci--); setTimeout(typeLoop, 34); }
    else { erasing = false; ri = (ri + 1) % roles.length; setTimeout(typeLoop, 300); }
  }
}
typeLoop();

const avatarCircle = document.getElementById('avatarCircle');
const burstColors = ['#00d4ff','#00ff9d','#f5c542','#ff6b6b','#a78bfa','#fb7185'];
const avAnims = [
  { keyframes: [{ transform:'scale(1) translateY(0)' },{ transform:'scale(0.88) translateY(-28px)' },{ transform:'scale(1.08) translateY(4px)' },{ transform:'scale(1) translateY(0)' }] },
  { keyframes: [{ transform:'rotate(0) scale(1)' },{ transform:'rotate(360deg) scale(1.15)' },{ transform:'rotate(720deg) scale(1)' }] },
  { keyframes: [{ transform:'translateX(0) rotate(0)' },{ transform:'translateX(-12px) rotate(-6deg)' },{ transform:'translateX(12px) rotate(6deg)' },{ transform:'translateX(0) rotate(0)' }] },
  { keyframes: [{ boxShadow:'0 0 40px rgba(0,212,255,0.1)' },{ boxShadow:'0 0 80px rgba(245,197,66,0.6), 0 0 0 3px rgba(245,197,66,0.4)' },{ boxShadow:'0 0 40px rgba(0,212,255,0.1)' }] }
];
avatarCircle.addEventListener('click', function(e) {
  const anim = avAnims[Math.floor(Math.random() * avAnims.length)];
  this.animate(anim.keyframes, { duration: 700, easing: 'cubic-bezier(0.34,1.56,0.64,1)' });
  for (let i = 0; i < 12; i++) {
    const el = document.createElement('div');
    el.className = 'emoji-burst';
    const color = burstColors[Math.floor(Math.random() * burstColors.length)];
    el.innerHTML = `<svg width="14" height="14" viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="${color}" stroke="${color}" stroke-width="1"/></svg>`;
    el.style.left = e.clientX + 'px'; el.style.top = e.clientY + 'px';
    const angle = (i / 12) * Math.PI * 2, dist = 70 + Math.random() * 55;
    el.style.setProperty('--tx', Math.cos(angle) * dist + 'px');
    el.style.setProperty('--ty', Math.sin(angle) * dist + 'px');
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 1000);
  }
});

document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', function() {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    this.classList.add('active');
    const f = this.dataset.filter;
    document.querySelectorAll('.project-card').forEach(card => {
      const cat = card.dataset.category || '', show = f === 'all' || cat.split(' ').includes(f);
      if (show) { card.style.transition = 'opacity 0.35s, transform 0.35s'; card.style.display = ''; requestAnimationFrame(() => { card.style.opacity = '1'; card.style.transform = ''; }); }
      else { card.style.opacity = '0'; card.style.transform = 'scale(0.92)'; setTimeout(() => { card.style.display = 'none'; }, 350); }
    });
  });
});

const form = document.getElementById('contactForm');
const fmsg = document.getElementById('formMsg');
if (form) {
  form.addEventListener('submit', function(e) {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]'), orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg> Sending...';
    try {
      emailjs.sendForm('service_aabh9889', 'template_9w48p7u', this)
        .then(() => {
          fmsg.className = 'form-msg success'; fmsg.textContent = 'Message sent! I\'ll reply within 24 hours.'; form.reset(); btn.innerHTML = 'Message Sent!';
          setTimeout(() => { btn.disabled = false; btn.innerHTML = orig; fmsg.className = 'form-msg'; fmsg.textContent = ''; }, 6000);
        }, () => {
          fmsg.className = 'form-msg error'; fmsg.textContent = 'Failed to send. Email directly: ay9526194@gmail.com'; btn.disabled = false; btn.innerHTML = orig;
        });
    } catch(err) { fmsg.className = 'form-msg error'; fmsg.textContent = 'Failed. Email directly: ay9526194@gmail.com'; btn.disabled = false; btn.innerHTML = orig; }
  });
}

document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  });
});

document.getElementById('footerYear').textContent = new Date().getFullYear();

})();
</script>
</body>
</html>
